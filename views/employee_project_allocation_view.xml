<?xml version="1.0" encoding="UTF-8"?>
<odoo>

    <!-- Tree View -->
    <record id="view_employee_project_allocation_tree" model="ir.ui.view">
        <field name="name">employee.project.allocation.tree</field>
        <field name="model">employee.project.allocation</field>
        <field name="arch" type="xml">

            <list>
                <field name="contract_id"/>
                <field name="employee_id"/>
                <field name="analytic_account_id"/>
                <field name="percentage"/>
            </list>
        </field>
    </record>


    <!-- Form View -->
    <record id="view_employee_project_allocation_form" model="ir.ui.view">
        <field name="name">employee.project.allocation.form</field>
        <field name="model">employee.project.allocation</field>
        <field name="arch" type="xml">

            <form string="Employee Project Allocation">
                <sheet>

                    <group>
                        <field name="contract_id"/>
                        <field name="employee_id"/>
                        <field name="analytic_account_id"/>
                        <field name="percentage"/>
                    </group>

                </sheet>
            </form>

        </field>
    </record>


    <!-- Action -->
    <record id="action_employee_project_allocation" model="ir.actions.act_window">
        <field name="name">Employee Project Allocation</field>
        <field name="res_model">employee.project.allocation</field>
        <field name="view_mode">list,form</field>
    </record>


    <!-- Optional Menu (for admin debugging) -->
    <menuitem
        id="menu_employee_project_allocation_root"
        name="Project Payroll Allocation"
        parent="hr_work_entry_contract_enterprise.menu_hr_payroll_root"
        sequence="80"/>

    <menuitem
        id="menu_employee_project_allocation"
        name="Employee Allocations"
        parent="menu_employee_project_allocation_root"
        action="action_employee_project_allocation"
        sequence="1"/>

</odoo>