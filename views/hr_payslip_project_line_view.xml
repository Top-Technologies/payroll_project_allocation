<odoo>

    <!-- Tree View -->
    <record id="view_payslip_project_line_tree" model="ir.ui.view">
        <field name="name">payslip.project.line.tree</field>
        <field name="model">hr.payslip.project.line</field>
        <field name="arch" type="xml">

            <list>
                <field name="payslip_id"/>
                <field name="employee_id"/>
                <field name="analytic_account_id"/>
                <field name="percentage"/>
                <field name="amount"/>
            </list>

        </field>
    </record>

    <record id="view_payslip_project_line_pivot" model="ir.ui.view">
        <field name="name">payslip.project.line.pivot</field>
        <field name="model">hr.payslip.project.line</field>
        <field name="arch" type="xml">
            <pivot string="Payroll by Project">

                <!-- ROWS -->
                <field name="analytic_account_id" type="row"/>
                <field name="employee_id" type="row"/>

                <!-- MEASURES -->
                <field name="amount" type="measure"/>
                <field name="percentage" type="measure"/>

            </pivot>
        </field>
    </record>

    <record id="view_payslip_project_line_graph" model="ir.ui.view">
        <field name="name">payslip.project.line.graph</field>
        <field name="model">hr.payslip.project.line</field>
        <field name="arch" type="xml">
            <graph string="Payroll by Project" type="bar">

                <!-- X Axis -->
                <field name="analytic_account_id"/>

                <!-- Measure -->
                <field name="amount"/>

            </graph>
        </field>
    </record>


    <!-- Action -->
    <record id="action_payslip_project_line" model="ir.actions.act_window">
        <field name="name">Payroll by Project</field>
        <field name="res_model">hr.payslip.project.line</field>
        <field name="view_mode">list,pivot,graph</field>

        <!-- Default pivot view -->
        <field name="view_id" ref="view_payslip_project_line_pivot"/>
    </record>

    <menuitem
        id="menu_payroll_project_root"
        name="Payroll Projects"
        parent="hr.menu_hr_root"
        sequence="60"/>
    <!-- Menu -->
    <menuitem
        id="menu_payroll_project_report"
        name="Payroll by Project"
        parent="menu_payroll_project_root"
        action="action_payslip_project_line"
        sequence="10"/>

</odoo>