<odoo>
    <record id="view_hr_payslip_form_inherit_project" model="ir.ui.view">
        <field name="name">hr.payslip.form.project.allocation</field>
        <field name="model">hr.payslip</field>
        <field name="inherit_id" ref="hr_payroll.view_hr_payslip_form"/>
        <field name="arch" type="xml">

            <xpath expr="//notebook" position="inside">
                <page string="Project Allocation">
                    <!-- <button name="compute_project_allocation"
                            type="object"
                            string="Compute Project Distribution"
                            class="btn-primary"/> -->
                    <field name="project_line_ids">
                        <list editable="bottom">
                            <field name="analytic_account_id"/>
                            <field name="percentage"/>
                            <field name="amount"/>
                        </list>
                    </field>
                </page>


            </xpath>

        </field>
    </record>
</odoo>